# =============================================================================
# Insique Frontend — Environment Configuration
# =============================================================================
# Copy this file to .env.local and adjust for your environment.
# =============================================================================

# ---- Backend API URL (REQUIRED) ----
# The URL of the deployed FastAPI backend including the API prefix.
#
# Production example:
#   NEXT_PUBLIC_FASTAPI_BASE_URL=https://insique-production.up.railway.app/api/v1
#
# Local development:
NEXT_PUBLIC_FASTAPI_BASE_URL=http://localhost:8000/api/v1
FASTAPI_BASE_URL=http://localhost:8000/api/v1
